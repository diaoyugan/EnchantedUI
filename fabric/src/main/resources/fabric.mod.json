{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "Enchanted UI",
  "description": "A Minecraft GUI API for building modular and composable UI screens.",
  "authors": [
    "钓鱼竿呀(diaoyugan)",
    "momo(HarukaB,aka AYARI on modrinth)"
  ],
  "contact": {
    "sources": "https://github.com/diaoyugan/EnchantedUI",
    "issues": "https://github.com/diaoyugan/EnchantedUI/issues",
    "email": "diaoyugan666@qq.com"
  },
  "license": "${license}",
  "icon": "assets/${mod_id}/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "top.diaoyugan.enchanted_ui.client.EnchantedUIClient"
    ],
    "modmenu": [
      "top.diaoyugan.enchanted_ui.client.configScreen.ModMenuIntegration"
    ]
  },
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": ">=${fabric_version}",
    "minecraft": ">=${fabric_minecraft_version}",
    "java": ">=${java_version}"
  },
  "suggests": {
  },
  "custom": {
    "modmenu": {
      "update_checker": true,
      "badges": [ "library" ]
    }
  }
}
